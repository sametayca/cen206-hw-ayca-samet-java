@startuml
skinparam componentStyle uml2
skinparam rectangle {
  BackgroundColor #438DD5
  BorderColor #3C7FC0
  FontColor white
}

skinparam database {
  BackgroundColor #438DD5
  BorderColor #3C7FC0
  FontColor white
}

skinparam actor {
  BackgroundColor #08427B
  BorderColor #073B6F
  FontColor white
}

skinparam collections {
  BackgroundColor #686868
  BorderColor #8A8A8A
  FontColor white
}

rectangle "<size:18><b><<person>></b></size>\n\n**User**\n\nPerson tracking nutrition and diet" as user #08427B

rectangle "Nutrition and Recipe Tracking System" as system {
  rectangle "<size:16><b><<container>></b></size>\n\n**Console Interface**\n\n[Java]\nConsole-based user interface for\naccessing the system" as interface
  
  rectangle "<size:16><b><<container>></b></size>\n\n**Java Application**\n\n[Java]\nMain application for nutrition tracking\nand recipe management" as application
  
  database "<size:16><b><<container>></b></size>\n\n**Database**\n\n[SQLite]\nStores user information and\nfood products" as db
  
  rectangle "<size:16><b><<container>></b></size>\n\n**Nutrition Analysis Module**\n\n[Java]\nCalculates BMI and provides\nnutrition recommendations" as analysis
}

rectangle "<size:16><b><<external_system>></b></size>\n\n**Delicious Recipes**\n\nExternal recipe database" as recipes #686868
rectangle "<size:16><b><<external_system>></b></size>\n\n**Nutritional Values System**\n\nExternal nutritional values database" as nutrition #686868

user -down-> interface : "Uses"
interface -down-> application : "Connects to"
application -left-> db : "Exchanges data"
application -right-> analysis : "Uses"
analysis -down-> recipes : "Integrates with\n[FUTURE]"
analysis -down-> nutrition : "Integrates with\n[FUTURE]"

@enduml